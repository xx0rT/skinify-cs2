/*
  # Security Headers
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()

  # Content Security Policy
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://challenges.cloudflare.com https://skinify.gg https://sandbox-merchant.revolut.com https://merchant.revolut.com https://translate.google.com https://translate.googleapis.com https://translate-pa.googleapis.com https://static.sumsub.com; script-src-elem 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://challenges.cloudflare.com https://skinify.gg https://sandbox-merchant.revolut.com https://merchant.revolut.com https://translate.google.com https://translate.googleapis.com https://translate-pa.googleapis.com https://static.sumsub.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://translate.googleapis.com https://www.gstatic.com https://static.sumsub.com; font-src 'self' https://fonts.gstatic.com https://static.sumsub.com; img-src 'self' data: https: blob:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.revolut.com https://merchant.revolut.com https://sandbox-merchant.revolut.com https://steamcommunity.com https://steamcommunity-a.akamaihd.net https://community.akamai.steamstatic.com https://cdn.akamai.steamstatic.com https://steamcdn-a.akamaihd.net https://*.steamstatic.com https://community.cloudflare.steamstatic.com https://cdn.cloudflare.steamstatic.com https://ipapi.co https://api.country.is https://api.ipify.org https://skinify.gg https://translate.googleapis.com https://api.sumsub.com https://*.sumsub.com wss://*.sumsub.com; frame-src 'self' https://challenges.cloudflare.com https://merchant.revolut.com https://sandbox-merchant.revolut.com https://translate.google.com https://translate.googleapis.com https://translate-pa.googleapis.com https://*.sumsub.com; object-src 'none'; base-uri 'self'; form-action 'self';

  # Cloudflare DDoS Protection Headers
  CF-Cache-Status: DYNAMIC
  CF-Ray: $http_cf_ray

  # Strict Transport Security (HTTPS only)
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Indexing: explicitly tell crawlers the page IS indexable + followable.
  # Previously this header was `X-Robots-Tag: none` which is identical to
  # noindex,nofollow and was the reason Google Search Console reported
  # "Excluded by 'noindex' tag" in X-Robots-Tag for every URL. The
  # X-Robots HTTP header overrides any <meta name="robots"> in the HTML,
  # so the page-level public defaults in MetaResetter.tsx were being
  # silently negated for every crawl.
  X-Robots-Tag: index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1

/api/*
  # API Rate Limiting Headers
  X-RateLimit-Limit: 100
  X-RateLimit-Window: 60

  # CORS for API endpoints
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: GET, POST, PUT, DELETE, OPTIONS
  Access-Control-Allow-Headers: Content-Type, Authorization, X-Client-Info, Apikey

/auth/*
  # Auth endpoints - stricter security
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  # Auth pages must not be indexed — login/signup flows are private.
  X-Robots-Tag: noindex, nofollow

# Private routes — explicitly noindex at the header level so search
# engines never surface user-account pages even if a stale link gets
# crawled. The HTML meta robots already says the same, but headers
# override and act as a belt-and-braces guarantee.
/profile
  X-Robots-Tag: noindex, nofollow
/profile/*
  X-Robots-Tag: noindex, nofollow
/cart
  X-Robots-Tag: noindex, nofollow
/cart/*
  X-Robots-Tag: noindex, nofollow
/onboarding
  X-Robots-Tag: noindex, nofollow
/onboarding/*
  X-Robots-Tag: noindex, nofollow
/admin
  X-Robots-Tag: noindex, nofollow
/admin/*
  X-Robots-Tag: noindex, nofollow
/messages
  X-Robots-Tag: noindex, nofollow
/messages/*
  X-Robots-Tag: noindex, nofollow

# Image Caching - Cache images for 7 days
/*.webp
  Cache-Control: public, max-age=604800, immutable

/*.png
  Cache-Control: public, max-age=604800, immutable

/*.jpg
  Cache-Control: public, max-age=604800, immutable

/*.jpeg
  Cache-Control: public, max-age=604800, immutable

/*.svg
  Cache-Control: public, max-age=604800, immutable

/*.gif
  Cache-Control: public, max-age=604800, immutable

# Audio Files - Cache for 7 days
/*.mp3
  Cache-Control: public, max-age=604800, immutable

# PWA manifest — explicit MIME so hosts that don't auto-resolve it
# (Cloudflare Pages, some Netlify routes) return 200 instead of 403.
/manifest.webmanifest
  Content-Type: application/manifest+json
  Cache-Control: public, max-age=3600
  Access-Control-Allow-Origin: *

# Sitemap + robots
/sitemap.xml
  Content-Type: application/xml
  Cache-Control: public, max-age=3600

/robots.txt
  Content-Type: text/plain
  Cache-Control: public, max-age=3600
